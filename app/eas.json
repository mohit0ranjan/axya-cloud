{
  "cli": {
    "version": ">= 18.0.5",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://axya-server.onrender.com",
        "EXPO_PUBLIC_SHARE_BASE_URL": "https://axya-web.onrender.com",
        "EXPO_PUBLIC_SITE_URL": "https://axya-web.onrender.com",
        "EXPO_PUBLIC_BASE_URL": "https://axya-web.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://axya-server.onrender.com",
        "EXPO_PUBLIC_SHARE_BASE_URL": "https://axya-web.onrender.com",
        "EXPO_PUBLIC_SITE_URL": "https://axya-web.onrender.com",
        "EXPO_PUBLIC_BASE_URL": "https://axya-web.onrender.com"
      }
    }
  }
}
