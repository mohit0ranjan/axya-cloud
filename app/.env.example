# Production/staging API (used in non-dev builds)
EXPO_PUBLIC_API_URL=https://axya-server.onrender.com
EXPO_PUBLIC_SHARE_BASE_URL=https://axya-web.onrender.com

# Optional local override for dev builds (`npm start` / Expo dev)
# If you set this, it overrides the default above during development.
EXPO_PUBLIC_DEV_API_URL=
