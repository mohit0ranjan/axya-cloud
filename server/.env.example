NODE_ENV=development
PORT=3000

# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=replace-with-strong-random-secret
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-with-telegram-api-hash
TELEGRAM_SESSION=replace-with-telegram-string-session
# Optional dedicated storage account (recommended for public shares)
TELEGRAM_STORAGE_SESSION=
TELEGRAM_STORAGE_CHAT_ID=me

# Required in production
COOKIE_SECRET=replace-with-strong-cookie-secret

# Recommended
ALLOWED_ORIGINS=https://axya-web.onrender.com,http://localhost:3000,http://localhost:3001,http://localhost:8081

# Optional share/space overrides
SERVER_BASE_URL=https://axya-server.onrender.com
FRONTEND_BASE_URL=https://axya-web.onrender.com
SHARE_PUBLIC_BASE_URL=https://axya-web.onrender.com
WEB_PUBLIC_BASE_URL=https://axya-web.onrender.com
SHARE_LINK_SECRET=
SHARE_ACCESS_SECRET=
SHARE_ACCESS_TOKEN_TTL=12h
SHARE_V2_SESSION_SECRET=
SHARE_V2_TICKET_SECRET=
SHARE_V2_LINK_PEPPER=
SHARE_V2_TICKET_TTL_SECONDS=600
SHARE_V2_META_CACHE_TTL_SECONDS=20
SHARE_V2_LOOKUP_CACHE_TTL_SECONDS=20
SHARE_V2_ITEMS_CACHE_TTL_SECONDS=12
HEALTH_DB_TIMEOUT_MS=1200
SPACE_ACCESS_SECRET=
SIGNED_DOWNLOAD_SECRET=
SHARED_SPACE_MAX_UPLOAD_BYTES=209715200
STORAGE_QUOTA_ENABLED=false
