{
  "expo": {
    "name": "Axya",
    "slug": "axya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/axya_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/axya_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mohit.axya",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/axya_logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/axya_logo.png"
      }
    },
    "web": {
      "favicon": "./assets/axya_logo.png"
    },
    "plugins": [
      "expo-sharing",
      "expo-image",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "87856e9d-b57b-47f9-a492-ce90a79e2e3b"
      }
    },
    "owner": "mohit010"
  }
}
